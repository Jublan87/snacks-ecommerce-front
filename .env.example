# Server-side: Next.js server → Backend (can be internal URL in production)
API_URL=http://localhost:4000/api

# Client-side: Browser → Backend
NEXT_PUBLIC_API_URL=http://localhost:4000/api

# SEO / Metadata (used in layout.tsx, sitemap.ts, robots.ts)
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Shipping configuration
NEXT_PUBLIC_FREE_SHIPPING_THRESHOLD=10000
NEXT_PUBLIC_SHIPPING_COST=1500
